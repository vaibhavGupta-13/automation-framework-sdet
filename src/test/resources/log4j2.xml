<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <properties>
        <property name="pattern">[%d{yyyy-MM-dd HH:mm:ss}] [%-5level] %logger{36} - %msg%n</property>
    </properties>
    <appenders>
        <Console name="ConsoleAppender">
            <PatternLayout pattern="${pattern}"/>
        </Console>
    </appenders>
    <loggers>
        <root level="all">
            <appender-ref ref="ConsoleAppender"/>
        </root>
    </loggers>
</configuration>